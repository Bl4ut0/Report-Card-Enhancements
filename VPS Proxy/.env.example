# Public DNS name pointed at this VPS.
DOMAIN=proxy.example.com

# Shared secrets sent by the Google Apps Script wrappers.
WCL_PROXY_SECRET=replace_with_a_long_random_value
DISCORD_PROXY_SECRET=replace_with_a_different_long_random_value

# WCL retry, timeout, and cache behavior.
WCL_PROXY_MAX_RETRIES=2
WCL_PROXY_MAX_BACKOFF_MS=15000
WCL_PROXY_REQUEST_TIMEOUT_MS=60000
WCL_PROXY_CACHE_TTL_SECONDS=300
WCL_PROXY_STALE_TTL_SECONDS=86400

# Process-wide queues. Keep one app container so these limits are global.
WCL_MAX_CONCURRENT=1
WCL_LAUNCH_SPACING_MS=300
WCL_V2_MAX_CONCURRENT=4
WCL_V2_LAUNCH_SPACING_MS=0

# Discord relay pacing and timeout.
DISCORD_QUEUE_INTERVAL_MS=500
DISCORD_REQUEST_TIMEOUT_MS=30000
