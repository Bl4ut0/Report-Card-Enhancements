# Warcraft Logs V1/V2 Comparison Test Runner Environment Variables
# Copy this file to .env inside the tests/ directory.

# Warcraft Logs API credentials
WCL_V1_API_KEY=your_wcl_v1_api_key_here
WCL_V2_CLIENT_ID=your_wcl_v2_client_id_here
WCL_V2_CLIENT_SECRET=your_wcl_v2_client_secret_here

# Cloudflare Worker proxy endpoint & secret
WCL_PROXY_URL=https://your-worker-subdomain.workers.dev/wcl
WCL_PROXY_SECRET=your_wcl_proxy_secret_here

# Default Warcraft Logs report code to run tests against
TEST_REPORT_CODE=TmNwkjXayJKtcR4W
