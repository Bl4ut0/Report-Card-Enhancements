# ==============================================================================
# Self-Hosted Proxy Configuration Template
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Required Routing Secrets
# ------------------------------------------------------------------------------
# These secrets must match the properties configured inside your Google Sheet.
WCL_PROXY_SECRET=replace_with_a_long_random_secret_password
DISCORD_PROXY_SECRET=replace_with_a_different_long_random_secret_password

# ------------------------------------------------------------------------------
# 2. VPS Settings (Caddy automatic SSL)
# ------------------------------------------------------------------------------
# Required ONLY when deploying on a public VPS using docker-compose.vps.yml.
# Do not include 'https://' or sub-paths. E.g., proxy.yourdomain.com
DOMAIN=proxy.yourdomain.com

# ------------------------------------------------------------------------------
# 3. Warcraft Logs Behavior (Optional - defaults shown)
# ------------------------------------------------------------------------------
WCL_PROXY_MAX_RETRIES=2
WCL_PROXY_MAX_BACKOFF_MS=15000
WCL_PROXY_REQUEST_TIMEOUT_MS=60000
WCL_PROXY_CACHE_TTL_SECONDS=300
WCL_PROXY_STALE_TTL_SECONDS=86400

# Concurrency limits and pacing (process-wide queues)
WCL_MAX_CONCURRENT=1
WCL_LAUNCH_SPACING_MS=300
WCL_V2_MAX_CONCURRENT=4
WCL_V2_LAUNCH_SPACING_MS=0

# ------------------------------------------------------------------------------
# 4. Discord Webhook Pacing (Optional - defaults shown)
# ------------------------------------------------------------------------------
DISCORD_QUEUE_INTERVAL_MS=500
DISCORD_REQUEST_TIMEOUT_MS=30000
