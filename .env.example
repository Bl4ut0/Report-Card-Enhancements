# Warcraft Logs & Discord Webhook Proxy Configuration
# Copy this file to .env and configure the values before running or testing.

# ── Warcraft Logs API Credentials ───────────────────────────────────────────
WCL_V1_API_KEY=your_wcl_v1_api_key_here
WCL_V2_CLIENT_ID=your_wcl_v2_client_id_here
WCL_V2_CLIENT_SECRET=your_wcl_v2_client_secret_here

# ── Cloudflare Worker Proxy Settings ─────────────────────────────────────────
WCL_PROXY_URL=https://your-worker.workers.dev/wcl
WCL_PROXY_SECRET=your_wcl_proxy_secret_here

DISCORD_PROXY_URL=https://your-worker.workers.dev/discord
DISCORD_PROXY_SECRET=your_discord_proxy_secret_here

# ── Test Runner Configurations ──────────────────────────────────────────────
TEST_REPORT_CODE=TmNwkjXayJKtcR4W
